
Algoritmo contar_hasta_10
	//definimos i como digito el cual va a seguir la secuencia
		Definir i Como Entero
		Escribir "iniciando lanzamiento"
		//adaptamos la secuencia de acuerdo a los requerimientos solicitados
		Para i <- 0 Hasta 33 Con Paso 3 Hacer
			Escribir i
		FinPara
		//se genera la secuencia y con el "space" se borra la secuencia permitiendo nuevamente la secuencia
		Esperar Tecla
		Limpiar Pantalla
FinAlgoritmo
